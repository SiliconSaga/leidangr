#!/usr/bin/env bash
# dev-secrets — render .env.local from OpenBao. The ONLY supported local secret path.
#
# Resolves the OpenBao target (BAO_ADDR direct URL when set — the contributor path
# — else a kubectl port-forward, the cluster-owner path), logs in via OIDC (browser
# -> Keycloak), reads the leidangr dev-scope KV, and hands the JSON to
# run-dev-secrets.mjs which validates + renders .env.local using the tested logic.
#
# The running Backstage never learns which OpenBao backs it; it only reads .env.local.
set -euo pipefail

KV_PATH="secret/leidangr/dev"
PF_PID=""
cleanup() { [[ -n "$PF_PID" ]] && kill "$PF_PID" 2>/dev/null || true; }
trap cleanup EXIT

if [[ -n "${BAO_ADDR:-}" ]]; then
  echo "dev-secrets: using OpenBao at $BAO_ADDR (direct)"
else
  echo "dev-secrets: port-forwarding OpenBao (svc/openbao -> 127.0.0.1:8200)"
  kubectl -n openbao port-forward svc/openbao 8200:8200 >/dev/null 2>&1 &
  PF_PID=$!
  export BAO_ADDR="http://127.0.0.1:8200"
  sleep 2
fi

echo "dev-secrets: logging in to OpenBao via OIDC (a browser window will open)..."
bao login -method=oidc >/dev/null

echo "dev-secrets: reading ${KV_PATH} ..."
bao kv get -format=json "${KV_PATH}" \
  | node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/lib/run-dev-secrets.mjs
